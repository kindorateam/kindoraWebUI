		"@tanstack/react-query": "^5.82.0",
		"@tanstack/react-router": "^1.125.6",
		"@tanstack/react-router-devtools": "^1.123.2",
		"axios": "^1.10.0",
		"clsx": "^2.1.1",
		"framer-motion": "^12.18.1",
		"jotai": "^2.12.5",
		"jwt-decode": "^4.0.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-hook-form": "^7.64.0",
		"tailwindcss": "^4.1.12"
