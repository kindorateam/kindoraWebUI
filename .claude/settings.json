{
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_NEW_INIT": "1"
	},
	"permissions": {
		"allow": [
			"Bash(bun run check:*)",
			"Bash(bun run check)",
			"Bash(bun run build)",
			"Bash(bun run dev:*)",
			"Bash(bun run fix:*)",
			"Bash(bun run typecheck:*)",
			"Bash(bun run biome:*)",
			"Bash(bun add:*)",
			"Bash(bun install:*)",
			"Bash(bun remove:*)",

			"Bash(git add:*)",
			"Bash(git branch:*)",
			"Bash(git checkout:*)",
			"Bash(git commit:*)",
			"Bash(git diff:*)",
			"Bash(git log:*)",
			"Bash(git merge:*)",
			"Bash(git push:*)",
			"Bash(git rebase:*)",
			"Bash(git stash:*)",
			"Bash(git status:*)",
			"Bash(gh:*)",

			"Bash(cat:*)",
			"Bash(cp:*)",
			"Bash(curl:*)",
			"Bash(echo:*)",
			"Bash(grep:*)",
			"Bash(ls:*)",
			"Bash(lsof:*)",
			"Bash(mkdir:*)",
			"Bash(mv:*)",
			"Bash(node -e:*)",
			"Bash(python3:*)",
			"Bash(rm:*)",
			"Bash(wc:*)",
			"Bash(which:*)",

			"mcp__figma__get_screenshot",
			"mcp__figma__get_design_context",
			"mcp__figma__get_metadata",

			"WebFetch(domain:localhost)",
			"WebFetch(domain:tanstack.com)",
			"WebFetch(domain:www.heroui.com)",
			"WebFetch(domain:raw.githubusercontent.com)",
			"WebFetch(domain:icon-sets.iconify.design)",
			"WebFetch(domain:api.iconify.design)"
		],
		"deny": [],
		"ask": []
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "jq -r '.tool_input.file_path // empty' | grep -q 'routeTree.gen.ts' && echo 'BLOCK: routeTree.gen.ts is auto-generated — never edit it' && exit 1 || exit 0",
						"timeout": 5,
						"statusMessage": "Checking protected files..."
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "jq -r '.tool_input.command // empty' | grep -qE 'git add.*(\\.(env|pem|key)|credentials)' && echo 'BLOCK: Do not stage secrets or credentials' && exit 1 || exit 0",
						"timeout": 5,
						"statusMessage": "Checking for secrets..."
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "cd /Users/aslanalyiev/Work/kindoraWeb && bun run typecheck 2>&1 | tail -5; bun run check 2>&1 | tail -5",
						"timeout": 60,
						"statusMessage": "Running verification..."
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; [[ \"$f\" =~ \\.(ts|tsx|js|jsx|json|css)$ ]] && bunx biome check --write \"$f\"; } 2>/dev/null || true",
						"timeout": 30,
						"statusMessage": "Formatting..."
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "bun x ccusage statusline"
	}
}
