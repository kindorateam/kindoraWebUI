//@version=6
indicator("Monte Carlo Fan Chart", overlay=true, max_boxes_count=500, max_lines_count=500, max_polylines_count=100, max_labels_count=100, max_bars_back=5000)

// ============================== INPUTS ==============================
string gControls = "Primary Controls"
int   simulations = input.int(750,   "Number of Simulations", group=gControls, minval=50,  step=50)
int   lookback    = input.int(500,   "Lookback",              group=gControls, minval=50,  step=50)
int   steps       = input.int(5,     "Steps Into Future",     group=gControls, minval=2,   maxval=100, step=1, tooltip="Forecast horizon in bars. ~5 is the sweet spot — matches the block length where the model has real predictive edge. Beyond ~8 it's mostly noise. Capped at 100 (Pine future-bar / runtime limits).")
int   bins        = input.int(50,    "Outcome Granularity",   group=gControls, minval=10,  maxval=500, step=5)
int   blockLen    = input.int(5,     "Block Length",          group=gControls, minval=1,   step=1, tooltip="Expected length of resampled return blocks (stationary bootstrap). Preserves volatility clustering / short-term autocorrelation.")
float smoothing   = input.float(1.75,"Outcome Smoothing",     group=gControls, minval=0.0, step=0.25)
string quality    = input.string("Balanced", "Quality", group=gControls, options=["Fast", "Balanced", "Accurate", "Research"], tooltip="Scales effective simulations. Fast=300, Balanced=your setting, Accurate=≥1500, Research=≥3000. Heavier = cleaner but may hit Pine's time limit.")
int   userSeed    = input.int(987654321, "Random Seed", group=gControls, minval=1, tooltip="Change for a different but reproducible random draw.")

string gAdj = "Additional Adjustments"
int    driftLength   = input.int(34, "Drift", group=gAdj, inline="drift", minval=0)
string driftStyle    = input.string("Standard", "Style:", group=gAdj, inline="drift", options=["Linear Regression", "Standard", "Historical Mean", "None"], tooltip="Standard = vol-degraded mean log return. Linear Regression = trend slope. Historical Mean = average return. None = zero drift (trendless).")
bool   volatilityAdj = input.bool(true, "Volatility Adjust", group=gAdj, tooltip="Use an EWMA volatility estimate (reactive to recent regime) instead of the plain sample stdev.")
bool   useLog        = input.string("Log Returns", "Returns Style", group=gAdj, options=["Percent", "Log Returns"]) == "Log Returns"
string forecastBase  = input.string("Close", "Forecast Base", group=gAdj, options=["Close", "Open"], tooltip="Price the forecast projects from. Close = current live price (recommended). Open = this bar's open (can be stale on long candles).")
bool   waitForSteps  = input.bool(false, "Update Every Bar", group=gAdj, tooltip="On = recompute on every closed candle. Off (default) = recompute every `steps` bars, letting each forecast run its full horizon.")
bool   realtime      = input.bool(false, "Real-time (Every Tick)", group=gAdj, tooltip="Recompute the whole simulation on every incoming tick. Heavy — may hit Pine's calculation-time limit at high simulation counts. Uses a deterministic per-bar seed so the picture stays stable within a bar and only shifts as price moves.")
int    throttleSecs  = input.int(1, "Real-time Throttle (sec)", group=gAdj, minval=0, tooltip="In real-time mode, recompute at most once per this many seconds (wall-clock). 0 = every tick (heaviest).")

string gVis = "Visual Preferences"
bool   showFan    = input.bool(true,  "Show Fan Bands",             group=gVis)
bool   showMedian = input.bool(true,  "Show Median Path",           group=gVis)
bool   showTerm   = input.bool(true,  "Show Terminal Distribution", group=gVis)
bool   showPct    = input.bool(true,  "Distribution % Labels",      group=gVis, tooltip="Print each bin's probability on the terminal distribution.")
bool   showBias   = input.bool(false, "Bull/Bear Bias",             group=gVis, tooltip="Small bull/bear table (superseded by the Summary panel).")
bool   showSummary= input.bool(true,  "Summary Panel",              group=gVis, tooltip="Everything you need to read it: bias, most-likely price, median target, 50% zone, 90% range.")
bool   startLine  = input.bool(true,  "Starting Line",              group=gVis)

string gCol = "Color Preferences"
color colBull   = input.color(#26C281, "Bullish", group=gCol, inline="c")
color colBear   = input.color(#FF4D4D, "Bearish", group=gCol, inline="c")
color colMedian = input.color(#FFB617, "Median",  group=gCol)
color colStart  = input.color(#7E7E7E, "Start",   group=gCol)
color colText   = input.color(#FFFFFF, "Text",    group=gCol)

// Range half-width in sigmas. TUNING TARGET: drop to 4.0 if the cone/histogram looks coarse.
const float K_SIGMA = 5.0

// ============================== PRNG ==============================
// Numerical Recipes LCG. Deterministic -> stable redraws. State threaded explicitly.
const int LCG_MOD = 4294967296  // 2^32

rng(int state) =>
    int next = (1664525 * state + 1013904223) % LCG_MOD
    [next / float(LCG_MOD), next]        // float division -> [float in [0,1), new state]

rng_int(int state, int n) =>
    [v, next] = rng(state)
    [int(v * n), next]                   // int in [0, n)

// ============================== MODEL ==============================
// Returns over `lb` bars, demeaned so drift is added back explicitly (no double count).
// sigma is EWMA when volatilityAdj is on, else the plain sample stdev.
prep_returns(int lb, bool logRet, bool ewma) =>
    array<float> R = array.new<float>()
    for i = 0 to lb - 1
        float r = logRet ? math.log(close[i] / close[i + 1]) : (close[i] - close[i + 1]) / close[i + 1]
        R.push(r)
    float mu       = R.avg()
    float sampleSd = R.stdev()
    float sigma    = sampleSd
    if ewma
        // EWMA variance, lambda = 0.94 (RiskMetrics), seeded with sample variance.
        float lambda = 0.94
        float v = math.pow(sampleSd, 2)
        for i = R.size() - 1 to 0
            float d = R.get(i) - mu
            v := lambda * v + (1.0 - lambda) * d * d
        sigma := math.sqrt(v)
    // Rescale residuals to the chosen volatility so the simulated PATH magnitude reacts to
    // current vol regime (not just the bin ranges). scale = 1 when EWMA off (sigma == sampleSd).
    float scale = sampleSd > 0.0 ? sigma / sampleSd : 1.0
    array<float> Rdm = array.new<float>()
    for i = 0 to R.size() - 1
        Rdm.push((R.get(i) - mu) * scale)
    [Rdm, mu, sigma, scale]

// Uses math.sum (rolling window) instead of a history-operator loop, so it stays
// consistent when called once per bar at global scope (avoids CW10003).
standard_drift(int len) =>
    float lr   = math.log(close / close[1])
    float mean = math.sum(lr, len) / len
    float msq  = math.sum(lr * lr, len) / len
    float vari = math.max(msq - mean * mean, 0.0)   // true variance E[r²]-mean², not E[r²]
    mean - 0.5 * vari

lin_reg_slope(int len) =>
    float sx = 0.0, float sy = 0.0, float sx2 = 0.0, float sxy = 0.0
    for i = 0 to len - 1
        float src = close[i]
        int   x   = i + 1
        sx  += x
        sy  += src
        sx2 += math.pow(x, 2)
        sxy += src * x
    -((len * sxy - sx * sy) / (len * sx2 - sx * sx))

// Per-step drift expressed in RETURN units (so it composes with bootstrapped returns).
// Standard -> log-return (precomputed at global scope); Linear Regression -> slope/price; None -> sample mean.
drift_term(int driftLen, string style, float mu, float dStd) =>
    int len = driftLen == 0 ? lookback : driftLen
    switch style
        "Standard"          => dStd
        "Linear Regression" => lin_reg_slope(len) / close
        "Historical Mean"   => mu
        => 0.0   // "None" = truly no drift (trendless)

// Analytic per-step price range: open * exp(±K*sigma*sqrt(t)). Single pass, no range discovery.
build_ranges(float basePrice, float sigma, int nsteps, bool logRet) =>
    array<float> lowArr  = array.new<float>()
    array<float> highArr = array.new<float>()
    array<float> bwArr   = array.new<float>()
    for t = 1 to nsteps
        float hw = K_SIGMA * sigma * math.sqrt(t)
        float lo = logRet ? basePrice * math.exp(-hw) : math.max(0.0, basePrice * (1 - hw))
        float hi = logRet ? basePrice * math.exp(hw)  : basePrice * (1 + hw)
        // Guard zero variance: give a degenerate but non-zero width so binning never divides by 0.
        if hi - lo <= 0.0
            lo := basePrice * 0.9999
            hi := basePrice * 1.0001
        lowArr.push(lo)
        highArr.push(hi)
        bwArr.push((hi - lo) / bins)
    [lowArr, highArr, bwArr]

// ============================== BINNING ==============================
bin_index(float price, float lo, float bw) =>
    int idx = bw > 0 ? int((price - lo) / bw) : 0
    math.max(0, math.min(bins - 1, idx))   // clamp into edge bins

// Run all sims in a single pass; fill `binsM` (steps x bins) and return clamp count + state.
// Stationary bootstrap (Politis-Romano): blocks restart with probability 1/L, so block length
// is random with mean L — avoids the periodicity artifacts of fixed-length blocks. Sampling is
// inlined (no per-sim path array) for speed.
run_simulations(array<float> R, int L, int nsteps, int nsims, float basePrice, float dterm, bool logRet, array<float> lowArr, array<float> bwArr, matrix<int> binsM, int state) =>
    int   st       = state
    int   clamps   = 0
    int   n        = R.size()
    float pRestart = L > 0 ? 1.0 / L : 1.0
    for sim = 0 to nsims - 1
        float p   = basePrice
        int   src = 0
        for t = 0 to nsteps - 1
            bool restart = t == 0
            if not restart
                [u, stu] = rng(st)
                st := stu
                restart := u < pRestart
            if restart
                [srcNew, sts] = rng_int(st, n)
                st  := sts
                src := srcNew
            else
                src := (src + 1) % n
            float r    = R.get(src)
            float mult = logRet ? math.exp(r + dterm) : math.max(0.000001, 1.0 + r + dterm)  // percent floor: price can't go ≤0
            p := p * mult
            float lo = lowArr.get(t)
            float bw = bwArr.get(t)
            int   idx = bin_index(p, lo, bw)
            if p < lo or p > lo + bw * bins
                clamps += 1
            binsM.set(t, idx, binsM.get(t, idx) + 1)
    [clamps, st]

// Percentile price for step row `t`: walk the CDF to the bin where it crosses p, return bin center.
pctl_price(matrix<int> bm, int t, float p, array<float> lowArr, array<float> bwArr, int nbins) =>
    int total = 0
    for c = 0 to nbins - 1
        total += bm.get(t, c)
    float target = p * total
    int   cum    = 0
    int   hit    = nbins - 1
    for c = 0 to nbins - 1
        cum += bm.get(t, c)
        if cum >= target
            hit := c
            break
    lowArr.get(t) + (hit + 0.5) * bwArr.get(t)

// ============================== RENDER ==============================
var array<box>  fanBoxes  = array.new<box>()
var array<box>  termBoxes = array.new<box>()
var polyline    medianLine = na
var line        startLn    = na
var label       clampLbl   = na
var table       biasTable  = table.new(position.top_right, 2, 2, border_width=1)
var table       sumTable   = table.new(position.bottom_right, 2, 9, border_width=1, frame_width=1, frame_color=color.new(color.gray, 50))

clear_boxes(array<box> arr) =>
    if arr.size() > 0
        for i = arr.size() - 1 to 0
            arr.get(i).delete()
            arr.remove(i)

render_fan(matrix<int> bm, int nsteps, array<float> lowArr, array<float> bwArr, int nbins, float basePrice, color cBull, color cBear, color cText, bool showPct) =>
    clear_boxes(fanBoxes)
    array<float> levels = array.from(0.05, 0.25, 0.50, 0.75, 0.95)
    for t = 0 to nsteps - 1
        int  xL    = bar_index + t
        int  xR    = bar_index + t + 1
        bool last  = t == nsteps - 1   // label only the rightmost column
        for g = 0 to levels.size() - 2
            float top    = pctl_price(bm, t, levels.get(g + 1), lowArr, bwArr, nbins)
            float bot    = pctl_price(bm, t, levels.get(g),     lowArr, bwArr, nbins)
            float center = (top + bot) / 2
            color base   = center >= basePrice ? cBull : cBear
            int   transp = (g == 1 or g == 2) ? 60 : 80   // inner gaps brighter
            float mass   = (levels.get(g + 1) - levels.get(g)) * 100.0   // probability mass in this band
            string txt   = showPct and last ? str.tostring(mass, "#") + "%" : ""
            box b = box.new(xL, top, xR, bot, border_color=#00000000, bgcolor=color.new(base, transp), text=txt, text_color=cText, text_size=size.normal, text_halign=text.align_right)
            fanBoxes.push(b)

// Returns the new polyline; caller reassigns the global var (Pine forbids reassigning globals in fns).
render_median(polyline prev, matrix<int> bm, int nsteps, array<float> lowArr, array<float> bwArr, int nbins, float basePrice, color c) =>
    if not na(prev)
        prev.delete()
    array<chart.point> pts = array.new<chart.point>()
    pts.push(chart.point.from_index(bar_index, basePrice))
    for t = 0 to nsteps - 1
        float p50 = pctl_price(bm, t, 0.50, lowArr, bwArr, nbins)
        pts.push(chart.point.from_index(bar_index + t + 1, p50))
    polyline.new(pts, line_color=c, line_width=2, closed=false)

sinc(float x, float bw) =>
    float omega = math.pi * x / bw
    x != 0.0 ? math.sin(omega) / omega : 1.0

smooth_row(matrix<int> bm, int t, int nbins, float len) =>
    array<float> raw = array.new<float>()
    for c = 0 to nbins - 1
        raw.push(bm.get(t, c))
    array<float> result = raw
    if len > 0.0
        array<float> est = array.new<float>()
        for i = 0 to nbins - 1
            float sum = 0.0, float sumw = 0.0
            for j = 0 to nbins - 1
                float w = sinc(i - j, len + 1.0)
                sum  += w * raw.get(j)
                sumw += w
            est.push(math.max(0.0, sum / sumw))
        result := est
    result

render_terminal(matrix<int> bm, int nsteps, array<float> lowArr, array<float> bwArr, int nbins, float smooth, float basePrice, color cBull, color cBear, color cText, bool showPct) =>
    clear_boxes(termBoxes)
    int   t   = nsteps - 1
    array<float> row = smooth_row(bm, t, nbins, smooth)
    float maxv = row.max()
    int   x0   = bar_index + nsteps
    float lo   = lowArr.get(t)
    float bw   = bwArr.get(t)
    // True probability from RAW counts (smoothing only shapes the bar length, not the %).
    int total = 0
    for c = 0 to nbins - 1
        total += bm.get(t, c)
    for c = 0 to nbins - 1
        float v = row.get(c)
        if v > 0 and maxv > 0
            float center = lo + (c + 0.5) * bw
            int   width  = int(30 * v / maxv)   // horizontal length scaled to max freq
            color base   = center >= basePrice ? cBull : cBear
            float prob   = total > 0 ? 100.0 * bm.get(t, c) / total : 0.0
            string txt   = showPct and prob >= 0.05 ? str.tostring(prob, "#.##") + "%" : ""
            box b = box.new(x0, lo + (c + 1) * bw, x0 + width, lo + c * bw, border_color=#00000000, bgcolor=color.new(base, 30), text=txt, text_color=cText, text_size=size.small, text_halign=text.align_left)
            termBoxes.push(b)

// Returns the new line; caller reassigns the global var.
render_start(line prev, float basePrice, color c) =>
    if not na(prev)
        prev.delete()
    line.new(bar_index, basePrice, bar_index + 1, basePrice, color=c, extend=extend.left)

// Bull/Bear bias: total probability of finishing above vs below the start price,
// measured from the terminal step's bins. Rendered into the persistent biasTable.
render_bias(matrix<int> bm, int nsteps, array<float> lowArr, array<float> bwArr, int nbins, float basePrice, color cBull, color cBear, color cText) =>
    int t = nsteps - 1
    int bull = 0
    int bear = 0
    float lo = lowArr.get(t)
    float bw = bwArr.get(t)
    for c = 0 to nbins - 1
        float center = lo + (c + 0.5) * bw
        int   cnt    = bm.get(t, c)
        if center >= basePrice
            bull += cnt
        else
            bear += cnt
    int   total    = bull + bear
    float bullPct  = total > 0 ? 100.0 * bull / total : 0.0
    float bearPct  = total > 0 ? 100.0 * bear / total : 0.0
    string lead    = bullPct >= bearPct ? "▲ BULLS" : "▼ BEARS"
    biasTable.cell(0, 0, lead, text_color=cText, bgcolor=bullPct >= bearPct ? cBull : cBear, text_size=size.normal)
    biasTable.cell(1, 0, str.tostring(math.max(bullPct, bearPct), "#.#") + "%", text_color=cText, bgcolor=bullPct >= bearPct ? cBull : cBear, text_size=size.normal)
    biasTable.cell(0, 1, "▲ " + str.tostring(bullPct, "#.#") + "%", text_color=cText, bgcolor=color.new(cBull, 70), text_size=size.small)
    biasTable.cell(1, 1, "▼ " + str.tostring(bearPct, "#.#") + "%", text_color=cText, bgcolor=color.new(cBear, 70), text_size=size.small)

// Signed % move of a price vs the start price, e.g. "+1.4%".
fmt_move(float price, float base) =>
    float m = (price - base) / base * 100.0
    (m >= 0 ? "+" : "") + str.tostring(m, "#.##") + "%"

// One panel with everything needed to read the forecast: leader, most-likely price,
// median target, the 50% zone and the 90% range — all in price + % move.
render_summary(matrix<int> bm, int nsteps, array<float> lowArr, array<float> bwArr, int nbins, float basePrice, float volScale, color cBull, color cBear, color cText) =>
    int t = nsteps - 1
    float lo = lowArr.get(t)
    float bw = bwArr.get(t)
    int   bull   = 0
    int   bear   = 0
    int   maxC   = -1
    int   maxI   = 0
    float sumAbs = 0.0   // for expected (mean absolute) move
    for c = 0 to nbins - 1
        int cnt = bm.get(t, c)
        float center = lo + (c + 0.5) * bw
        if center >= basePrice
            bull += cnt
        else
            bear += cnt
        if cnt > maxC
            maxC := cnt
            maxI := c
        sumAbs += cnt * math.abs(center - basePrice)
    int   total    = bull + bear
    float bullPct  = total > 0 ? 100.0 * bull / total : 0.0
    float bearPct  = 100.0 - bullPct
    bool  bullLead = bullPct >= bearPct
    float modeP    = lo + (maxI + 0.5) * bw
    float p05 = pctl_price(bm, t, 0.05, lowArr, bwArr, nbins)
    float p25 = pctl_price(bm, t, 0.25, lowArr, bwArr, nbins)
    float p50 = pctl_price(bm, t, 0.50, lowArr, bwArr, nbins)
    float p75 = pctl_price(bm, t, 0.75, lowArr, bwArr, nbins)
    float p95 = pctl_price(bm, t, 0.95, lowArr, bwArr, nbins)
    // Expected move = probability-weighted mean absolute move, as % of base.
    float expMove = (total > 0 and basePrice > 0) ? (sumAbs / total) / basePrice * 100.0 : 0.0
    // Skew = which tail is fatter (upper vs lower distance around the median).
    float upTail   = p95 - p50
    float downTail = p50 - p05
    string skewTxt = upTail > downTail * 1.1 ? "Up-tail heavy" : downTail > upTail * 1.1 ? "Down-tail heavy" : "Symmetric"
    color cHdr   = color.new(#1E222D, 0)   // near-black header
    color cLeft  = color.new(#2A2E39, 0)   // dark label cells
    color cRight = color.new(#363A45, 0)   // slightly lighter value cells
    sumTable.cell(0, 0, "🎯 Forecast: " + str.tostring(nsteps) + " bars ahead", text_color=color.white, bgcolor=cHdr, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 0, "", bgcolor=cHdr)
    sumTable.merge_cells(0, 0, 1, 0)
    sumTable.cell(0, 1, "Bias", text_color=color.white, bgcolor=cLeft, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 1, (bullLead ? "▲ Bulls " : "▼ Bears ") + str.tostring(math.max(bullPct, bearPct), "#") + "%", text_color=color.white, bgcolor=bullLead ? cBull : cBear, text_size=size.normal)
    sumTable.cell(0, 2, "Most likely", text_color=color.white, bgcolor=cLeft, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 2, str.tostring(modeP, format.mintick) + "  (" + fmt_move(modeP, basePrice) + ")", text_color=color.white, bgcolor=cRight, text_size=size.normal)
    sumTable.cell(0, 3, "Median (P50)", text_color=color.white, bgcolor=cLeft, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 3, str.tostring(p50, format.mintick) + "  (" + fmt_move(p50, basePrice) + ")", text_color=color.white, bgcolor=cRight, text_size=size.normal)
    sumTable.cell(0, 4, "50% zone", text_color=color.white, bgcolor=cLeft, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 4, str.tostring(p25, format.mintick) + " … " + str.tostring(p75, format.mintick), text_color=color.white, bgcolor=cRight, text_size=size.normal)
    sumTable.cell(0, 5, "90% range", text_color=color.white, bgcolor=cLeft, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 5, str.tostring(p05, format.mintick) + " … " + str.tostring(p95, format.mintick), text_color=color.white, bgcolor=cRight, text_size=size.normal)
    sumTable.cell(0, 6, "Exp. move", text_color=color.white, bgcolor=cLeft, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 6, "±" + str.tostring(expMove, "#.##") + "%", text_color=color.white, bgcolor=cRight, text_size=size.normal)
    sumTable.cell(0, 7, "Skew", text_color=color.white, bgcolor=cLeft, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 7, skewTxt, text_color=color.white, bgcolor=cRight, text_size=size.normal)
    sumTable.cell(0, 8, "Vol scale", text_color=color.white, bgcolor=cLeft, text_size=size.normal, text_halign=text.align_left)
    sumTable.cell(1, 8, str.tostring(volScale, "#.##") + "x", text_color=color.white, bgcolor=cRight, text_size=size.normal)

// ============================== DRIVER ==============================
var float seed = userSeed

// Effective simulations from the Quality preset.
int simsEff = switch quality
    "Fast"     => math.min(simulations, 300)
    "Accurate" => math.max(simulations, 1500)
    "Research" => math.max(simulations, 3000)
    => simulations  // "Balanced"

// Computed on EVERY bar (not inside the conditional) so its rolling history stays consistent.
float dStdGlobal = standard_drift(driftLength == 0 ? lookback : driftLength)

if barstate.islast
    // prep_returns reads close[lookback] (i+1 at i=lookback-1) -> needs bar_index >= lookback.
    if bar_index < lookback
        runtime.error('Use a "Lookback" less than available bars: ' + str.tostring(bar_index))
    if bar_index < driftLength
        runtime.error('Use a "Drift" less than available bars: ' + str.tostring(bar_index))
    if steps * bins > 100000
        runtime.error('steps × Outcome Granularity must be ≤ 100,000 (Pine matrix limit). Lower Steps or Granularity.')

    var int counter  = -1
    var int lastCalc = 0
    counter += 1
    // Initial paint must fire ONCE on load, not every tick. The old `counter == 0 ? true`
    // stayed true for the whole first forming bar (counter only commits at bar close),
    // causing intrabar redraws. barstate.isnew is true only on a bar's first tick -> fires once.
    bool initial = counter == 0 and barstate.isnew
    // Real-time throttle: recompute at most once per `throttleSecs` (0 = every tick).
    bool tickReady = throttleSecs == 0 or counter == 0 or (timenow - lastCalc >= throttleSecs * 1000)
    bool wait = realtime ? tickReady : (initial or (not waitForSteps ? (barstate.isconfirmed and 0 == counter % steps) : barstate.isconfirmed))

    if wait
        // Real-time: reseed deterministically per bar so the picture is stable within a bar
        // (only price drift changes it), not jittering on every tick from an advancing seed.
        if realtime
            seed     := bar_index * 7919 + userSeed
            lastCalc := timenow
        float basePrice = forecastBase == "Close" ? close : open
        [Rdm, mu, sigma, volScale] = prep_returns(lookback, useLog, volatilityAdj)
        float dterm = drift_term(driftLength, driftStyle, mu, dStdGlobal)
        [lowArr, highArr, bwArr] = build_ranges(basePrice, sigma, steps, useLog)

        matrix<int> binsM = matrix.new<int>(steps, bins, 0)
        [clamps, sEnd] = run_simulations(Rdm, blockLen, steps, simsEff, basePrice, dterm, useLog, lowArr, bwArr, binsM, int(seed))
        seed := sEnd

        if showFan
            render_fan(binsM, steps, lowArr, bwArr, bins, basePrice, colBull, colBear, colText, showPct)
        if showMedian
            medianLine := render_median(medianLine, binsM, steps, lowArr, bwArr, bins, basePrice, colMedian)
        if showTerm
            render_terminal(binsM, steps, lowArr, bwArr, bins, smoothing, basePrice, colBull, colBear, colText, showPct)
        if startLine
            startLn := render_start(startLn, basePrice, colStart)
        if showBias
            render_bias(binsM, steps, lowArr, bwArr, bins, basePrice, colBull, colBear, colText)
        if showSummary
            render_summary(binsM, steps, lowArr, bwArr, bins, basePrice, volScale, colBull, colBear, colText)

        // Surface clamping only when significant — never silent truncation.
        // Reuse a single label (delete the previous) so real-time recomputes don't pile up.
        if not na(clampLbl)
            clampLbl.delete()
            clampLbl := na
        float clampPct = 100.0 * clamps / (simsEff * steps)
        if clampPct > 1.0
            clampLbl := label.new(bar_index + steps, highArr.get(steps - 1), "⚠ " + str.tostring(clampPct, "#.#") + "% clamped — raise K_SIGMA", color=color.new(color.orange, 60), textcolor=colText, style=label.style_label_left, size=size.small)
