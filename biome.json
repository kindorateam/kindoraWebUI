{
	"$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120,
		"lineEnding": "lf"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"nursery": {
				"useSortedClasses": {
					"level": "error",
					"options": {
						"attributes": ["classList"],
						"functions": ["clsx", "cva", "tw", "tw.*"]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"lineWidth": 120
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"identifierOrder": "lexicographic",
						"groups": [
							{ "type": false, "source": [":NODE:", ":PACKAGE:"] },
							":BLANK_LINE:",
							{ "type": false, "source": ["../**"] },
							":BLANK_LINE:",
							{ "type": false, "source": ["./**"] },
							":BLANK_LINE:",
							{ "type": false, "source": [":ALIAS:", "@/**"] },
							":BLANK_LINE:",
							{ "type": false, "source": ["."] },
							":BLANK_LINE:",
							{ "type": true },
							":BLANK_LINE:",
							["**/*.css", "**/*.scss", "**/*.sass"]
						]
					}
				}
			}
		}
	}
}
